# DO_NOT_UNDO — Environment variable template for Appeal Case Manager
# Copy this file to backend/.env and frontend/.env and fill in values
# Payment method: PayID ONLY. Stripe and PayPal are permanently removed.

# === Backend (.env) ===
MONGO_URL=mongodb://localhost:27017
DB_NAME=criminal_appeals
FRONTEND_URL=https://your-domain.com
ADMIN_EMAILS=admin@example.com
CONTACT_EMAIL=contact@example.com
EMERGENT_LLM_KEY=sk-emergent-your-key-here
RESEND_API_KEY=re_your-resend-key-here
CORS_ORIGINS=https://your-domain.com

# === Frontend (.env) ===
REACT_APP_BACKEND_URL=https://your-domain.com
WDS_SOCKET_PORT=443

# ============================================================
# Appeal Case Manager — Production Environment Reference
# ============================================================
# This file documents ALL required environment variables.
# Set backend variables in backend/.env (or hosting panel).
# Set frontend variables in frontend/.env (or hosting panel).
# DO NOT commit real .env files — see backend/.env.example and
# frontend/.env.example for per-service templates.

# === BACKEND ===

# MongoDB connection string
MONGO_URL=mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=criminal_appeals

# Public frontend URL (no trailing slash)
FRONTEND_URL=https://your-domain.com

# Comma-separated allowed CORS origins
CORS_ORIGINS=https://your-domain.com

# OpenAI API key (personal billing account)
OPENAI_API_KEY=sk-your-openai-key-here

# Google OAuth 2.0 credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Admin & contact
ADMIN_EMAILS=admin@your-domain.com
CONTACT_EMAIL=support@your-domain.com

# Email sending via Resend
RESEND_API_KEY=re_your-resend-api-key-here
RESEND_FROM_EMAIL=noreply@your-domain.com

# PayID payments (optional)
PAYID_EMAIL=payments@your-domain.com

# === FRONTEND ===

# Backend API base URL (no /api suffix)
REACT_APP_BACKEND_URL=https://your-railway-backend-url.railway.app

# Same Google Client ID as backend GOOGLE_CLIENT_ID
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Support contact shown on Help/FAQ pages (optional)
REACT_APP_SUPPORT_EMAIL=support@your-domain.com
REACT_APP_GOOGLE_PLAY_URL=
REACT_APP_IOS_APP_STORE_URL=

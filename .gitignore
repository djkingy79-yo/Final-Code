# DO_NOT_UNDO — .gitignore
# Dependencies
node_modules/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Build output
frontend/build/
dist/
*.whl

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Environment and credential files — NEVER commit secrets
backend/.env
frontend/.env
.env
.env.*
*.env
credentials.json
*.pem
*.key
.credentials

# Capacitor
frontend/android/
frontend/ios/

# Coverage
coverage/
htmlcov/
.coverage

# Misc
*.bak
*.tmp


# DO_NOT_UNDO — .gitignore
# Dependencies
node_modules/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Build output
frontend/build/
dist/
*.whl

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Credential files (NEVER commit secrets). NOTE: .env files intentionally NOT
# listed here — Emergent's native deployment pipeline REQUIRES backend/.env and
# frontend/.env to be committed so the deploy step can inject production
# values into them. The actual secret values live in Emergent's vault.
credentials.json
*.pem
*.key
.credentials
memory/test_credentials.md
/memory/test_credentials.md

# Capacitor
frontend/android/
frontend/ios/

# Coverage
coverage/
htmlcov/
.coverage

# Misc
*.bak
*.tmp


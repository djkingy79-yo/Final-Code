# DO_NOT_UNDO — .gitignore for Appeal Case Manager

# IDE and editors
.idea/
.vscode/

# Dependencies
node_modules/
/.pnp
.pnp.js
.yarn/install-state.gz

# Testing
/coverage

# Production builds
/build
dist/

# Environment files — local secrets only
# NOTE: frontend/.env and backend/.env are NOT ignored — deployment needs them
.env.local
.env.*.local
!frontend/.env
!backend/.env
!.env.example

# Credentials & secrets
*token.json*
*credentials.json*

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
*.so
venv/
.venv/

# Misc
*.tsbuildinfo
next-env.d.ts
/.next/
/out/
frontend/node_modules/.cache/default-development/0.pack
frontend/node_modules/.cache/default-development/1.pack
frontend/node_modules/.cache/default-development/2.pack

# .gitignore
#
# DO NOT commit `.env` files (backend/.env, frontend/.env).
# Secrets (OPENAI_API_KEY, MONGO_URL, GOOGLE_CLIENT_ID, etc.) must be
# provided via the hosting provider's environment/secrets panel, not stored
# in version control. CI will fail if backend/.env is committed.
#
# Dependencies
node_modules/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Build output
frontend/build/
dist/
*.whl

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Credential files — NEVER commit secrets.
credentials.json
*.pem
*.key
.credentials
memory/test_credentials.md
/memory/test_credentials.md

# .env.example template files only — NEVER ignore real .env files.
.env.example

# Capacitor
frontend/android/
frontend/ios/

# Coverage
coverage/
htmlcov/
.coverage

# Misc
*.bak
*.tmp

# Webpack cache
frontend/node_modules/.cache/

# Test reports and iteration logs (may contain secrets)
test_reports/
backend/tests/test_google_oauth_iteration*.py
backend/tests/test_security_fixes_iteration*.py
frontend/node_modules/.cache/default-development/25.pack
frontend/node_modules/.cache/default-development/32.pack
frontend/node_modules/.cache/default-development/27.pack

# Environment and credential files
.env
.env.*
*.env
credentials.json
*.pem
*.key
.credentials

frontend/node_modules/.cache/default-development/28.pack

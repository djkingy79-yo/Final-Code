# DO_NOT_UNDO — .gitignore. All entries in this file are approved and must be preserved.
# Dependencies
node_modules/
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/

# Build output
frontend/build/
dist/
*.whl

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log

# Environment files — NEVER commit secrets
backend/.env
frontend/.env
*.env.local
*.env.*.local

# Keep .env.example (template without secrets)
!backend/.env.example

# Webpack cache
frontend/node_modules/.cache/

# Test credentials
memory/test_credentials.md

# Legacy test files and audit docs
docs/audit/
backend/tests/legacy/
test_reports/*.pdf
test_reports/*.docx


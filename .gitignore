.yarn/install-state.gz

# Testing
/coverage

# Production builds
/build
dist/

# Environment files — NEVER commit secrets
.env
.env.local
.env.*.local
*.env
*.env.*
!.env.example

# Credentials & secrets
*token.json*
*credentials.json*
/memory/test_credentials.md

# Logs and debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS files
.DS_Store
Thumbs.db

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
*.so
venv/
.venv/


# ─── Appeal Case Manager — Backend Environment Variables ───
# Copy this file to .env and fill in all values.
# All variables are REQUIRED unless marked [optional].

# MongoDB
MONGO_URL=mongodb://localhost:27017
DB_NAME=appeal_case_manager

# Frontend URL (no trailing slash)
FRONTEND_URL=https://criminallawappealmanagement.com.au

# AI / LLM
EMERGENT_LLM_KEY=<emergent-api-key>

# Email (Resend)
RESEND_API_KEY=<resend-email-api-key>

# Admin
ADMIN_EMAILS=admin@example.com
CONTACT_EMAIL=support@example.com

# PayPal [optional — legacy, not actively used]
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_MODE=sandbox

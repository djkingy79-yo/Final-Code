# ============================================================
# Appeal Case Manager — Backend Environment Configuration
# ============================================================
# Copy to .env and fill in values. DO NOT commit .env to git.
#
# REQUIRED — Core
# ============================================================
MONGO_URL=mongodb://localhost:27017
DB_NAME=criminal_appeals

# ============================================================
# REQUIRED — Security & CORS
# ============================================================
# Comma-separated list of allowed frontend origins. NEVER use * in production.
CORS_ORIGINS=https://criminallawappealmanagement.com.au
# The frontend URL used for email links, OAuth callbacks, etc.
FRONTEND_URL=https://criminallawappealmanagement.com.au

# ============================================================
# REQUIRED — AI / LLM
# ============================================================
# Your personal OpenAI API key — billing goes to your own OpenAI account.
# Get it from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# ============================================================
# REQUIRED — Google OAuth
# ============================================================
# Create an OAuth 2.0 client at https://console.cloud.google.com/apis/credentials
# Set authorised redirect URI to: https://criminallawappealmanagement.com.au
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================================
# REQUIRED — Email (Resend)
# ============================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@criminallawappealmanagement.com.au
CONTACT_EMAIL=djkingy79@gmail.com

# ============================================================
# OPTIONAL — Admin & Payments
# ============================================================
# Your Gmail while you don't have a domain email yet.
# Once you have a domain email, change this to that address.
ADMIN_EMAILS=djkingy79@gmail.com
PAYID_EMAIL=djkingy79@gmail.com

# ============================================================
# OPTIONAL — Stripe (leave blank to disable)
# ============================================================
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ============================================================
# OPTIONAL — PayPal (leave blank to disable)
# ============================================================
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

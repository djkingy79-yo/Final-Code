# ============================================================
# Appeal Case Manager — Backend Environment Configuration
# ============================================================
# Copy to .env and fill in values. DO NOT commit .env to git.
#
# REQUIRED — Core
# ============================================================
MONGO_URL=mongodb://localhost:27017
DB_NAME=criminal_appeals

# ============================================================
# REQUIRED — Security & CORS
# ============================================================
# Comma-separated list of allowed frontend origins. NEVER use * in production.
CORS_ORIGINS=https://yourdomain.com.au
# The frontend URL used for email links, OAuth callbacks, etc.
FRONTEND_URL=https://yourdomain.com.au

# ============================================================
# REQUIRED — AI / LLM
# ============================================================
# Emergent universal key for GPT-4o (report generation, translation)
EMERGENT_LLM_KEY=

# ============================================================
# REQUIRED — Email (Resend)
# ============================================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com.au
CONTACT_EMAIL=admin@yourdomain.com.au

# ============================================================
# OPTIONAL — Admin & Payments
# ============================================================
ADMIN_EMAILS=admin@yourdomain.com.au
PAYID_EMAIL=payments@yourdomain.com.au

# ============================================================
# OPTIONAL — Stripe (leave blank to disable)
# ============================================================
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# ============================================================
# OPTIONAL — PayPal (leave blank to disable)
# ============================================================
# PAYPAL_CLIENT_ID=
# PAYPAL_CLIENT_SECRET=

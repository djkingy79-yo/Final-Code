# ============================================================
# Appeal Case Manager — Backend Environment Configuration
# ============================================================
# Copy to backend/.env and fill in values. DO NOT commit .env to git.
# Set all secrets via your hosting provider's environment panel.
#
# ============================================================
# REQUIRED — Database
# ============================================================
# MongoDB Atlas connection string (recommended for production)
# e.g. mongodb+srv://user:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://your-user:your-password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
DB_NAME=criminal_appeals

# ============================================================
# REQUIRED — Security & CORS
# ============================================================
# Comma-separated list of allowed frontend origins. NEVER use * in production.
CORS_ORIGINS=https://your-domain.com
# The public frontend URL — used for email links, OAuth callbacks, etc.
FRONTEND_URL=https://your-domain.com

# ============================================================
# REQUIRED — AI / LLM
# ============================================================
# Your personal OpenAI API key — billing goes to your own OpenAI account.
# Get it from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here

# ============================================================
# REQUIRED — Google OAuth
# ============================================================
# Create an OAuth 2.0 client at: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI:  https://your-domain.com/auth/callback
# Authorised JavaScript origin: https://your-domain.com
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ============================================================
# REQUIRED — Admin
# ============================================================
# Comma-separated list of email addresses granted admin access
ADMIN_EMAILS=admin@your-domain.com
# Primary contact / support email address
CONTACT_EMAIL=support@your-domain.com

# ============================================================
# REQUIRED — Email (Resend)
# ============================================================
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your-resend-api-key-here
# Must be a verified sender domain in your Resend account
RESEND_FROM_EMAIL=noreply@your-domain.com

# ============================================================
# OPTIONAL — Payments (PayID)
# ============================================================
# PayID email shown to clients for invoice payments
PAYID_EMAIL=payments@your-domain.com

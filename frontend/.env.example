# Appeal Case Manager — Frontend Environment
# Copy to .env and configure for your deployment.
#
# REQUIRED — API URL
# In development: http://localhost:8001/api or your preview URL
# In production: https://criminallawappealmanagement.com.au
REACT_APP_BACKEND_URL=https://criminallawappealmanagement.com.au

# REQUIRED — Google OAuth (same Client ID as backend GOOGLE_CLIENT_ID)
# Authorised JavaScript origin must be set to: https://criminallawappealmanagement.com.au
REACT_APP_GOOGLE_CLIENT_ID=

# DO NOT MODIFY — internal dev server config
WDS_SOCKET_PORT=443
ENABLE_HEALTH_CHECK=true

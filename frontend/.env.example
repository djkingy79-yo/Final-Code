# ============================================================
# Appeal Case Manager — Frontend Environment Configuration
# ============================================================
# Copy to .env and fill in values. DO NOT commit .env to git.

# ============================================================
# REQUIRED — Backend API URL
# In development: http://localhost:8001
# In production:  https://your-railway-backend-url.railway.app
# ============================================================
REACT_APP_BACKEND_URL=https://your-railway-backend-url.railway.app

# ============================================================
# REQUIRED — Google OAuth
# Same Client ID as GOOGLE_CLIENT_ID in backend/.env
# Authorised JavaScript origin must be: https://your-domain.com
# Get credentials at: https://console.cloud.google.com/apis/credentials
# ============================================================
REACT_APP_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# ============================================================
# OPTIONAL — Support & Contact
# Shown on Help/FAQ pages and in mobile app banner links
# ============================================================
REACT_APP_SUPPORT_EMAIL=support@your-domain.com
REACT_APP_GOOGLE_PLAY_URL=
REACT_APP_IOS_APP_STORE_URL=

# ============================================================
# DO NOT MODIFY — internal dev server config
# ============================================================
WDS_SOCKET_PORT=443
ENABLE_HEALTH_CHECK=true
